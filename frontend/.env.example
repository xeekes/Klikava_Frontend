# Backend API base URL (no trailing slash).
# FastAPI на EC2: http://<IP>:7777
# Оставь пустым для офлайн-режима без бэкенда (каталог будет пустым).
VITE_API_BASE_URL=

# Seller panel login (отдельное SPA admin/, порт 3001).
VITE_SELLER_PANEL_URL=http://localhost:3001/seller/login

# Пример для EC2:
# VITE_API_BASE_URL=http://<YOUR_SERVER_IP>:7777

# Основные эндпоинты витрины (FastAPI Marketplace API):
# POST /users/login
# POST /users/register
# GET  /users/me
# GET  /products?q=...&sort_by=popularity
# GET  /orders
# POST /orders
# GET  /orders/{id}/shipments
# POST /pictures/users/{user_id}
# DELETE /users/{user_id}
#
# Корзина (/cart) на бэкенде отсутствует — фронт хранит её в localStorage.

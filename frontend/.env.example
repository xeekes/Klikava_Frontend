# Backend API base URL (no trailing slash).
# FastAPI на EC2: http://<IP>:7777
# Оставь пустым для mock-режима.
VITE_API_BASE_URL=

# Seller panel login (отдельное SPA admin/, порт 3001).
VITE_SELLER_PANEL_URL=http://localhost:3001/seller/login

# Пример для EC2:
# VITE_API_BASE_URL=http://<YOUR_SERVER_IP>:7777

# Реальный бэкенд (FastAPI):
# POST /users/login      body: { login, password }  → data.access_token
# POST /users/register   body: { login, email, password, name }
# GET  /users/me         Authorization: Bearer <token>
# GET  /health
#
# Логин — это username (поле login), не email.
# Корзина (/cart) на бэкенде пока отсутствует — фронт хранит её локально.
